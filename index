// State stored in memory
const state = {
  puzzles: PUZZLES.map(p => ({ id: p.id, status: 'unsolved' })), // unsolved | solved | revealed
  revealTarget: null
};

function getPuzzleState(id) {
  return state.puzzles.find(p => p.id === id);
}

function setPuzzleStatus(id, status) {
  const ps = getPuzzleState(id);
  if (ps) ps.status = status;
  updateProgress();
}

function updateProgress() {
  const solved = state.puzzles.filter(p => p.status === 'solved').length;
  const revealed = state.puzzles.filter(p => p.status === 'revealed').length;
  const el = document.getElementById('progress-text');
  if (el) el.textContent = `${solved} / 10 solved${revealed > 0 ? ` (${revealed} revealed)` : ''}`;
}

function showHome() {
  setView('home');
}

function showList() {
  renderList();
  setView('list');
  updateProgress();
}

function showPuzzle(id) {
  state.currentPuzzleId = id;
  renderPuzzle(id);
  setView('puzzle');
}

function setView(id) {
  document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  window.scrollTo(0, 0);
}

function renderList() {
  const container = document.getElementById('puzzle-list');
  container.innerHTML = PUZZLES.map(p => {
    const ps = getPuzzleState(p.id);
    let statusClass = 'status-unsolved';
    let statusText = 'Unsolved';
    let cardClass = '';
    if (ps.status === 'solved') { statusClass = 'status-solved'; statusText = '✓ Solved'; cardClass = 'solved'; }
    if (ps.status === 'revealed') { statusClass = 'status-revealed'; statusText = '⚑ Revealed'; }

    return `
    <div class="puzzle-card ${cardClass}" onclick="tryOpenPuzzle(${p.id})">
      <div class="puzzle-num">${String(p.id).padStart(2,'0')}</div>
      <div class="puzzle-info">
        <h3>${p.title}</h3>
        <p>${p.type}</p>
      </div>
      <span class="puzzle-status ${statusClass}">${statusText}</span>
      <span class="puzzle-arrow">→</span>
    </div>`;
  }).join('');
}

function renderPuzzle(id) {
  const p = PUZZLES.find(x => x.id === id);
  const ps = getPuzzleState(id);
  document.getElementById('puzzle-nav-title').textContent = p.title;

  const isSolved = ps.status === 'solved';
  const isRevealed = ps.status === 'revealed';

  const hintsHTML = p.hints.map((h, i) => `
    <button class="btn-hint" id="hint-btn-${id}-${i}" onclick="revealHint(${id}, ${i})" ${isSolved && 'disabled'}>
      Hint ${i+1}
    </button>`).join('');

  const hintTextsHTML = p.hints.map((h, i) => `
    <div class="hint-text" id="hint-text-${id}-${i}" style="display:none">
      <span>Hint ${i+1}</span>${h}
    </div>`).join('');

  const revealedAnswerDisplay = (isRevealed || isSolved) ? `
    <div class="revealed-answer" id="revealed-answer-${id}" style="display:block">
      <span>${isSolved ? 'Correct answer' : 'Revealed answer'}</span>
      <strong>${p.answer.toUpperCase()}</strong>
    </div>` : `
    <div class="revealed-answer" id="revealed-answer-${id}" style="display:none">
      <span>Revealed answer</span>
      <strong>${p.answer.toUpperCase()}</strong>
    </div>`;

  const isFirst = id === PUZZLES[0].id;
  const isLast = id === PUZZLES[PUZZLES.length - 1].id;
  const nextId = isLast ? null : PUZZLES[PUZZLES.findIndex(x => x.id === id) + 1].id;
  const prevId = isFirst ? null : PUZZLES[PUZZLES.findIndex(x => x.id === id) - 1].id;

  const navRow = (pos) => `
    <div class="puzzle-nav-row ${pos}">
      ${prevId ? `<button class="btn-nav prev" onclick="navigatePuzzle(${prevId})">← Previous</button>` : `<span class="btn-nav invisible">placeholder</span>`}
      <button class="btn-nav" onclick="showList()">All Puzzles</button>
      ${nextId ? `<button class="btn-nav next" onclick="navigatePuzzle(${nextId})">Next →</button>` : `<span class="btn-nav invisible">placeholder</span>`}
    </div>`;

  document.getElementById('puzzle-content').innerHTML = `
    ${navRow('top')}
    <p class="puzzle-number-tag">Puzzle ${String(id).padStart(2,'0')} of ${PUZZLES.length}</p>
    <h2 class="puzzle-title">${p.title}</h2>
    <span class="puzzle-type-tag">${p.type}</span>

    <div class="puzzle-body">
      ${p.description}
    </div>

    ${p.acceptableAnswers.length > 0 ? `
    <div class="answer-section">
      <label>Your Answer</label>
      <div class="answer-row">
        <input class="answer-input" id="answer-input-${id}" type="text" placeholder="Type your answer here..." ${isSolved || isRevealed ? 'disabled' : ''} onkeydown="if(event.key==='Enter') submitAnswer(${id})">
        <button class="btn-submit" id="submit-btn-${id}" onclick="submitAnswer(${id})" ${isSolved || isRevealed ? 'disabled' : ''}>Submit</button>
      </div>
      <div class="answer-feedback" id="feedback-${id}" ${isSolved ? 'class="correct"' : isRevealed ? 'class="incorrect"' : ''} style="${isSolved ? 'display:block' : isRevealed ? 'display:block' : 'display:none'}">
        ${isSolved ? '✓ Correct! Well done.' : isRevealed ? 'Answer has been revealed.' : ''}
      </div>
    </div>

    ${p.hints.length > 0 ? `
    <div class="hints-section">
      <p class="hints-header">Need a nudge?</p>
      <div class="hint-buttons">${hintsHTML}</div>
      ${hintTextsHTML}
    </div>` : ''}

    <div class="reveal-section">
      <button class="btn-reveal" id="reveal-btn-${id}" onclick="openRevealModal(${id})" ${isSolved || isRevealed ? 'disabled style="opacity:0.4;cursor:not-allowed"' : ''}>
        Reveal Answer
      </button>
      <div class="reveal-confirm" id="reveal-confirm-${id}"></div>
      ${revealedAnswerDisplay}
    </div>
    ` : ''}
    ${navRow('bottom')}
  `;
}

function submitAnswer(id) {
  const p = PUZZLES.find(x => x.id === id);
  const input = document.getElementById(`answer-input-${id}`);
  const feedback = document.getElementById(`feedback-${id}`);
  const val = input.value.trim().toLowerCase();

  if (!val) return;

  const correct = p.acceptableAnswers.some(a => a.toLowerCase() === val);

  feedback.className = 'answer-feedback ' + (correct ? 'correct' : 'incorrect');
  feedback.style.display = 'block';

  if (correct) {
    feedback.textContent = '✓ Correct! Well done.';
    setPuzzleStatus(id, 'solved');
    document.getElementById(`answer-input-${id}`).disabled = true;
    document.getElementById(`submit-btn-${id}`).disabled = true;
    document.getElementById(`reveal-btn-${id}`).disabled = true;
    document.getElementById(`reveal-btn-${id}`).style.opacity = '0.4';
    document.getElementById(`reveal-btn-${id}`).style.cursor = 'not-allowed';
    // Show answer
    const ans = document.getElementById(`revealed-answer-${id}`);
    ans.querySelector('span').textContent = 'Correct answer';
    ans.style.display = 'block';
  } else {
    feedback.textContent = '✗ Not quite — try again, or use a hint.';
  }
}

function revealHint(puzzleId, hintIndex) {
  const textEl = document.getElementById(`hint-text-${puzzleId}-${hintIndex}`);
  const btnEl = document.getElementById(`hint-btn-${puzzleId}-${hintIndex}`);
  textEl.style.display = 'block';
  btnEl.classList.add('revealed');
  btnEl.textContent = `Hint ${hintIndex+1} ✓`;
}

function openRevealModal(id) {
  state.revealTarget = id;
  document.getElementById('reveal-modal').classList.add('open');
}

function closeRevealModal() {
  document.getElementById('reveal-modal').classList.remove('open');
  state.revealTarget = null;
}

function confirmReveal() {
  const id = state.revealTarget;
  closeRevealModal();
  if (!id) return;

  setPuzzleStatus(id, 'revealed');

  const feedback = document.getElementById(`feedback-${id}`);
  feedback.className = 'answer-feedback incorrect';
  feedback.style.display = 'block';
  feedback.textContent = 'Answer has been revealed.';

  document.getElementById(`answer-input-${id}`).disabled = true;
  document.getElementById(`submit-btn-${id}`).disabled = true;
  document.getElementById(`reveal-btn-${id}`).disabled = true;
  document.getElementById(`reveal-btn-${id}`).style.opacity = '0.4';

  const ans = document.getElementById(`revealed-answer-${id}`);
  ans.style.display = 'block';
}

// Close modal on overlay click
document.getElementById('reveal-modal').addEventListener('click', function(e) {
  if (e.target === this) closeRevealModal();
});
document.getElementById('spoiler-modal').addEventListener('click', function(e) {
  if (e.target === this) closeSpoilerModal();
});

// Spoiler warning state
state.spoilerTarget = null;

function navigatePuzzle(targetId) {
  // Check if current puzzle is unsolved — warn that next may have spoilers
  const currentId = state.currentPuzzleId;
  const currentStatus = getPuzzleState(currentId).status;
  if (currentStatus === 'unsolved') {
    openSpoilerModal(
      targetId,
      'You haven\'t solved this puzzle yet. The next puzzle may contain spoilers. Continue anyway?'
    );
  } else {
    showPuzzle(targetId);
  }
}

function tryOpenPuzzle(targetId) {
  // Called from puzzle list — warn if any previous puzzles are unsolved
  const targetIndex = PUZZLES.findIndex(p => p.id === targetId);
  if (targetIndex <= 0) { showPuzzle(targetId); return; }

  const previousPuzzles = PUZZLES.slice(0, targetIndex);
  const unsolvedPrevious = previousPuzzles.filter(p => {
    const ps = getPuzzleState(p.id);
    return ps.status === 'unsolved';
  });

  if (unsolvedPrevious.length > 0) {
    const names = unsolvedPrevious.length === 1
      ? `Puzzle ${unsolvedPrevious[0].id}`
      : `${unsolvedPrevious.length} previous puzzles`;
    openSpoilerModal(
      targetId,
      `You haven't completed ${names} yet. This puzzle may contain spoilers. Continue anyway?`
    );
  } else {
    showPuzzle(targetId);
  }
}

function openSpoilerModal(targetId, message) {
  state.spoilerTarget = targetId;
  document.getElementById('spoiler-modal-text').textContent = message;
  document.getElementById('spoiler-modal').classList.add('open');
}

function closeSpoilerModal() {
  document.getElementById('spoiler-modal').classList.remove('open');
  state.spoilerTarget = null;
}

function confirmSpoiler() {
  const targetId = state.spoilerTarget;
  closeSpoilerModal();
  if (targetId) showPuzzle(targetId);
}
</script>
